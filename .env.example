BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_USER_ID=your_telegram_user_id_here
# Optional: path to SQLite DB (default: yad2bot.db in current dir)
# DB_PATH=yad2bot.db
# Facebook Marketplace location (required to get Israeli listings).
# Without this, FB defaults to San Francisco for unauthenticated users.
#
# How to find your city's ID:
#   1. Open https://www.facebook.com/marketplace/ in your browser
#   2. Click the location box and type your city (e.g. "Tel Aviv")
#   3. Select it — the URL changes to /marketplace/XXXXXXXXX/
#   4. Copy that number here
#
FB_LOCATION_ID=109713862387616
